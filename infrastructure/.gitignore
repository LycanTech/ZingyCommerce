# Terraform state files — contain sensitive data, never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files — may contain secrets
terraform.tfvars
*.auto.tfvars

# Terraform working directory (downloaded provider binaries — do not commit)
.terraform/
# .terraform.lock.hcl is intentionally tracked — pins provider versions for reproducible runs

# Crash logs
crash.log
crash.*.log

# Sensitive override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files — can contain sensitive values
*.tfplan
